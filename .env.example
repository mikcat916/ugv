# Local-only development defaults. Copy this file to `.env` and adjust MySQL
# credentials if your local database uses different values.

# Web backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG=1

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=robot_monitor
MYSQL_CHARSET=utf8mb4

# Desktop database aliases
UAV_DB_HOST=127.0.0.1
UAV_DB_PORT=3306
UAV_DB_USER=root
UAV_DB_PASSWORD=
UAV_DB_NAME=robot_monitor

# Local auth defaults. Keep these for local use only.
SESSION_SECRET=dev-local-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=System Administrator
ALLOW_SELF_REGISTER=0

# Optional integrations
AMAP_WEB_KEY=

# Robot local defaults
ROBOT_CONTROL_MODE=direct
ROBOT_CAMERA_STALE_SECONDS=8
