# Local-only development defaults. Copy this file to `.env` and adjust MySQL
# credentials if your local database uses different values.

# Web backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG=1

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=robot_monitor
MYSQL_CHARSET=utf8mb4

# Local auth defaults. Keep these for local use only.
SESSION_SECRET=dev-local-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=System Administrator
ALLOW_SELF_REGISTER=0

# Optional integrations
AMAP_WEB_KEY=

# Control gateway. The backend and gateway must use the same token.
# dry_run is the safe default: requests are checked but no robot is contacted.
CONTROL_GATEWAY_URL=http://127.0.0.1:9100
CONTROL_GATEWAY_HOST=127.0.0.1
CONTROL_GATEWAY_PORT=9100
CONTROL_GATEWAY_TOKEN=replace-with-a-long-random-token
CONTROL_GATEWAY_TIMEOUT_SECONDS=5
CONTROL_GATEWAY_MODE=dry_run

# Robot local defaults
ROBOT_CONTROL_MODE=direct
ROBOT_CONTROL_PORT=9000
ROBOT_CONTROL_TIMEOUT_SECONDS=2
ROBOT_CAMERA_STALE_SECONDS=8
